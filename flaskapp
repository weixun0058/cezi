server {
    listen 80;
    server_name wx58.xyz www.wx58.xyz 106.55.145.186;

    # 托管静态文件（CSS/JS/图片）
    location /static {
        alias /home/sm58/static;
        expires 30d;
    }

    # 为所有其他请求（包括根路径和API）设置代理
    location / {
        proxy_pass http://unix:/tmp/flaskapp.sock;

        # SSE 支持配置
        proxy_buffering off;
        proxy_cache off;
        proxy_http_version 1.1;
        chunked_transfer_encoding off;

        # 超时设置
        proxy_read_timeout 24h;
        proxy_connect_timeout 24h;
        proxy_send_timeout 24h;

        # 代理头信息
        proxy_set_header Host $host;
        proxy_set_header X-Accel-Buffering no;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";

        # 设置跨域资源共享 (CORS)
        add_header 'Access-Control-Allow-Origin' '*' always;
        add_header 'Access-Control-Allow-Credentials' 'true' always;
        add_header 'Access-Control-Allow-Methods' 'GET, POST, OPTIONS' always;
        add_header 'Access-Control-Allow-Headers' 'Origin,Authorization,Accept,X-Requested-With,Content-Type' always;

        # 处理 OPTIONS 请求
        if ($request_method = OPTIONS) {
            add_header 'Access-Control-Allow-Origin' '*';
            add_header 'Access-Control-Allow-Methods' 'GET, POST, OPTIONS';
            add_header 'Access-Control-Allow-Headers' 'Origin,Authorization,Accept,X-Requested-With,Content-Type';
            add_header 'Access-Control-Max-Age' 1728000;
            add_header 'Content-Type' 'text/plain; charset=UTF-8';
            add_header 'Content-Length' 0;
            return 204;
        }
    }
}