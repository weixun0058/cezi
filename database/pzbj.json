{"\u7532\u4e0d\u5f00\u4ed3\u8d22\u7269\u8017\u6563\uff0c\u5b50\u4e0d\u95ee\u535c\u81ea\u60f9\u7978\u6b83": "\u4eca\u65e5\u4e0d\u9002\u5408\u5f00\u4ed3\u653e\u7cae\uff0c\u6309\u7167\u73b0\u5728\u7684\u8bf4\u6cd5\u5e94\u8be5\u662f\u4eca\u5929\u4e0d\u9002\u5408\u5927\u989d\u6d88\u8d39\u3001\u652f\u51fa\u2026\u2026\uff0c\u5e94\u8be5\u6025\u9700\u8d22\u5bcc\uff0c\u4ee5\u5907\u672a\u6765\u4e0d\u65f6\u4e4b\u9700\u3002\u4e5f\u4e0d\u9002\u5408\u505a\u7b97\u547d\u3001\u95ee\u5366\u3001\u770b\u76f8\u3001\u582a\u8206\u7684\u4e8b\u60c5\uff0c\u505a\u4e86\u4e5f\u4e0d\u4e00\u5b9a\u51c6\u786e\u3002", "\u7532\u4e0d\u5f00\u4ed3\u8d22\u7269\u8017\u6563\uff0c\u4e11\u4e0d\u51a0\u5e26\u4e3b\u4e0d\u8fd8\u4e61": "\u4eca\u65e5\u4e0d\u9002\u5408\u5f00\u4ed3\u653e\u7cae\uff0c\u6309\u7167\u73b0\u5728\u7684\u8bf4\u6cd5\u5e94\u8be5\u662f\u4eca\u5929\u4e0d\u9002\u5408\u5927\u989d\u6d88\u8d39\u3001\u652f\u51fa\u2026\u2026\uff0c\u5e94\u8be5\u6025\u9700\u8d22\u5bcc\uff0c\u4ee5\u5907\u672a\u6765\u4e0d\u65f6\u4e4b\u9700\u3002\u4e5f\u4e0d\u9002\u5408\u7a7f\u65b0\u8863\u670d\uff0c\u56de\u4e61\u3001\u56de\u8001\u5bb6\u4e4b\u7c7b\u7684\u4e8b\u60c5\u3002", "\u7532\u4e0d\u5f00\u4ed3\u8d22\u7269\u8017\u6563\uff0c\u5bc5\u4e0d\u796d\u7940\u795e\u9b3c\u4e0d\u5c1d": "\u4eca\u65e5\u4e0d\u9002\u5408\u5f00\u4ed3\u653e\u7cae\uff0c\u6309\u7167\u73b0\u5728\u7684\u8bf4\u6cd5\u5e94\u8be5\u662f\u4eca\u5929\u4e0d\u9002\u5408\u5927\u989d\u6d88\u8d39\u3001\u652f\u51fa\u2026\u2026\uff0c\u5e94\u8be5\u6025\u9700\u8d22\u5bcc\uff0c\u4ee5\u5907\u672a\u6765\u4e0d\u65f6\u4e4b\u9700\u3002\u4e5f\u4e0d\u9002\u5408\u796d\u7940\u3001\u6c42\u795e\u62dc\u4f5b\u4e4b\u7c7b\u7684\u4e8b\u60c5\u3002", "\u7532\u4e0d\u5f00\u4ed3\u8d22\u7269\u8017\u6563\uff0c\u536f\u4e0d\u7a7f\u4e95\u6c34\u6cc9\u4e0d\u9999": "\u4eca\u65e5\u4e0d\u9002\u5408\u5f00\u4ed3\u653e\u7cae\uff0c\u6309\u7167\u73b0\u5728\u7684\u8bf4\u6cd5\u5e94\u8be5\u662f\u4eca\u5929\u4e0d\u9002\u5408\u5927\u989d\u6d88\u8d39\u3001\u652f\u51fa\u2026\u2026\uff0c\u5e94\u8be5\u6025\u9700\u8d22\u5bcc\uff0c\u4ee5\u5907\u672a\u6765\u4e0d\u65f6\u4e4b\u9700\u3002\u4e5f\u4e0d\u9002\u5408\u5728\u8d44\u6e90\u672a\u6210\u719f\u65f6\u5f3a\u884c\u7d22\u53d6\u6216\u5f00\u53d1\u3002", "\u7532\u4e0d\u5f00\u4ed3\u8d22\u7269\u8017\u6563\uff0c\u8fb0\u4e0d\u54ed\u6ce3\u5fc5\u4e3b\u91cd\u4e27": "\u4eca\u65e5\u4e0d\u9002\u5408\u5f00\u4ed3\u653e\u7cae\uff0c\u6309\u7167\u73b0\u5728\u7684\u8bf4\u6cd5\u5e94\u8be5\u662f\u4eca\u5929\u4e0d\u9002\u5408\u5927\u989d\u6d88\u8d39\u3001\u652f\u51fa\u2026\u2026\uff0c\u5e94\u8be5\u6025\u9700\u8d22\u5bcc\uff0c\u4ee5\u5907\u672a\u6765\u4e0d\u65f6\u4e4b\u9700\u3002\u4e5f\u4e0d\u9002\u5408\u54ed\u6ce3\u3002\u4e5f\u5c31\u662f\u8981\u6ce8\u91cd\u4e2a\u4eba\u60c5\u7eea\u7ba1\u7406\u3002", "\u7532\u4e0d\u5f00\u4ed3\u8d22\u7269\u8017\u6563\uff0c\u5df3\u4e0d\u8fdc\u884c\u8d22\u7269\u4f0f\u85cf": "\u4eca\u65e5\u4e0d\u9002\u5408\u5f00\u4ed3\u653e\u7cae\uff0c\u6309\u7167\u73b0\u5728\u7684\u8bf4\u6cd5\u5e94\u8be5\u662f\u4eca\u5929\u4e0d\u9002\u5408\u5927\u989d\u6d88\u8d39\u3001\u652f\u51fa\u2026\u2026\uff0c\u5e94\u8be5\u6025\u9700\u8d22\u5bcc\uff0c\u4ee5\u5907\u672a\u6765\u4e0d\u65f6\u4e4b\u9700\u3002\u4e5f\u4e0d\u9002\u5408\u51fa\u95e8\u8fdc\u884c\uff0c\u6ce8\u610f\u8d22\u7269\u4fdd\u7ba1\uff0c\u907f\u514d\u4e22\u5931\u3002", "\u7532\u4e0d\u5f00\u4ed3\u8d22\u7269\u8017\u6563\uff0c\u5348\u4e0d\u82eb\u76d6\u5c4b\u4e3b\u66f4\u5f20": "\u4eca\u65e5\u4e0d\u9002\u5408\u5f00\u4ed3\u653e\u7cae\uff0c\u6309\u7167\u73b0\u5728\u7684\u8bf4\u6cd5\u5e94\u8be5\u662f\u4eca\u5929\u4e0d\u9002\u5408\u5927\u989d\u6d88\u8d39\u3001\u652f\u51fa\u2026\u2026\uff0c\u5e94\u8be5\u6025\u9700\u8d22\u5bcc\uff0c\u4ee5\u5907\u672a\u6765\u4e0d\u65f6\u4e4b\u9700\u3002\u4e5f\u4e0d\u9002\u5408\u5bf9\u623f\u5c4b\u4fee\u7f2e\uff0c\u4fee\u7406\u3002", "\u7532\u4e0d\u5f00\u4ed3\u8d22\u7269\u8017\u6563\uff0c\u672a\u4e0d\u670d\u836f\u6bd2\u6c14\u5165\u80a0": "\u4eca\u65e5\u4e0d\u9002\u5408\u5f00\u4ed3\u653e\u7cae\uff0c\u6309\u7167\u73b0\u5728\u7684\u8bf4\u6cd5\u5e94\u8be5\u662f\u4eca\u5929\u4e0d\u9002\u5408\u5927\u989d\u6d88\u8d39\u3001\u652f\u51fa\u2026\u2026\uff0c\u5e94\u8be5\u6025\u9700\u8d22\u5bcc\uff0c\u4ee5\u5907\u672a\u6765\u4e0d\u65f6\u4e4b\u9700\u3002\u8981\u5bf9\u5403\u836f\u8fdb\u8865\u4e4b\u7c7b\u7684\u4e8b\u60c5\u4fdd\u6301\u614e\u91cd\u3002", "\u7532\u4e0d\u5f00\u4ed3\u8d22\u7269\u8017\u6563\uff0c\u7533\u4e0d\u5b89\u5e8a\u9b3c\u795f\u5165\u623f": "\u4eca\u65e5\u4e0d\u9002\u5408\u5f00\u4ed3\u653e\u7cae\uff0c\u6309\u7167\u73b0\u5728\u7684\u8bf4\u6cd5\u5e94\u8be5\u662f\u4eca\u5929\u4e0d\u9002\u5408\u5927\u989d\u6d88\u8d39\u3001\u652f\u51fa\u2026\u2026\uff0c\u5e94\u8be5\u6025\u9700\u8d22\u5bcc\uff0c\u4ee5\u5907\u672a\u6765\u4e0d\u65f6\u4e4b\u9700\u3002\u4e0d\u9002\u5408\u79fb\u52a8\u3001\u5b89\u7f6e\u5e8a\u94fa\u3002", "\u7532\u4e0d\u5f00\u4ed3\u8d22\u7269\u8017\u6563\uff0c\u9149\u4e0d\u4f1a\u5ba2\u9189\u5750\u98a0\u72c2": "\u4eca\u65e5\u4e0d\u9002\u5408\u5f00\u4ed3\u653e\u7cae\uff0c\u6309\u7167\u73b0\u5728\u7684\u8bf4\u6cd5\u5e94\u8be5\u662f\u4eca\u5929\u4e0d\u9002\u5408\u5927\u989d\u6d88\u8d39\u3001\u652f\u51fa\u2026\u2026\uff0c\u5e94\u8be5\u6025\u9700\u8d22\u5bcc\uff0c\u4ee5\u5907\u672a\u6765\u4e0d\u65f6\u4e4b\u9700\u3002\u5982\u679c\u4eca\u65e5\u5bb4\u8bf7\u5ba2\u4eba\u6216\u8005\u8d74\u5bb4\uff0c\u8981\u5c0f\u5fc3\u559d\u9152\u559d\u9189\u3002", "\u7532\u4e0d\u5f00\u4ed3\u8d22\u7269\u8017\u6563\uff0c\u620c\u4e0d\u5403\u72ac\u4f5c\u602a\u4e0a\u5e8a": "\u4eca\u65e5\u4e0d\u9002\u5408\u5f00\u4ed3\u653e\u7cae\uff0c\u6309\u7167\u73b0\u5728\u7684\u8bf4\u6cd5\u5e94\u8be5\u662f\u4eca\u5929\u4e0d\u9002\u5408\u5927\u989d\u6d88\u8d39\u3001\u652f\u51fa\u2026\u2026\uff0c\u5e94\u8be5\u6025\u9700\u8d22\u5bcc\uff0c\u4ee5\u5907\u672a\u6765\u4e0d\u65f6\u4e4b\u9700\u3002\u4e0d\u8981\u5403\u72d7\u8089\u3002", "\u7532\u4e0d\u5f00\u4ed3\u8d22\u7269\u8017\u6563\uff0c\u4ea5\u4e0d\u5ac1\u5a36\u4e0d\u5229\u65b0\u90ce": "\u4eca\u65e5\u4e0d\u9002\u5408\u5f00\u4ed3\u653e\u7cae\uff0c\u6309\u7167\u73b0\u5728\u7684\u8bf4\u6cd5\u5e94\u8be5\u662f\u4eca\u5929\u4e0d\u9002\u5408\u5927\u989d\u6d88\u8d39\u3001\u652f\u51fa\u2026\u2026\uff0c\u5e94\u8be5\u6025\u9700\u8d22\u5bcc\uff0c\u4ee5\u5907\u672a\u6765\u4e0d\u65f6\u4e4b\u9700\u3002\u4e0d\u9002\u5408\u4eca\u65e5\u7ed3\u5a5a", "\u4e59\u4e0d\u683d\u690d\u5343\u682a\u4e0d\u957f\uff0c\u5b50\u4e0d\u95ee\u535c\u81ea\u60f9\u7978\u6b83": "\u4eca\u65e5\u4e0d\u9002\u5408\u683d\u690d\uff0c\u6309\u73b0\u5728\u7684\u8bf4\u6cd5\u5e94\u8be5\u662f\u4e0d\u9002\u5408\u505a\u6709\u5f00\u521b\u6027\u8d28\u7684\u4e8b\u60c5\u3002\u4e5f\u4e0d\u9002\u5408\u505a\u7b97\u547d\u3001\u95ee\u5366\u3001\u770b\u76f8\u3001\u582a\u8206\u7684\u4e8b\u60c5\uff0c\u505a\u4e86\u4e5f\u4e0d\u4e00\u5b9a\u51c6\u786e\u3002", "\u4e59\u4e0d\u683d\u690d\u5343\u682a\u4e0d\u957f\uff0c\u4e11\u4e0d\u51a0\u5e26\u4e3b\u4e0d\u8fd8\u4e61": "\u4eca\u65e5\u4e0d\u9002\u5408\u683d\u690d\uff0c\u6309\u73b0\u5728\u7684\u8bf4\u6cd5\u5e94\u8be5\u662f\u4e0d\u9002\u5408\u505a\u6709\u5f00\u521b\u6027\u8d28\u7684\u4e8b\u60c5\u3002\u4e5f\u4e0d\u9002\u5408\u7a7f\u65b0\u8863\u670d\uff0c\u56de\u4e61\u3001\u56de\u8001\u5bb6\u4e4b\u7c7b\u7684\u4e8b\u60c5\u3002", "\u4e59\u4e0d\u683d\u690d\u5343\u682a\u4e0d\u957f\uff0c\u5bc5\u4e0d\u796d\u7940\u795e\u9b3c\u4e0d\u5c1d": "\u4eca\u65e5\u4e0d\u9002\u5408\u683d\u690d\uff0c\u6309\u73b0\u5728\u7684\u8bf4\u6cd5\u5e94\u8be5\u662f\u4e0d\u9002\u5408\u505a\u6709\u5f00\u521b\u6027\u8d28\u7684\u4e8b\u60c5\u3002\u4e5f\u4e0d\u9002\u5408\u796d\u7940\u3001\u6c42\u795e\u62dc\u4f5b\u4e4b\u7c7b\u7684\u4e8b\u60c5\u3002", "\u4e59\u4e0d\u683d\u690d\u5343\u682a\u4e0d\u957f\uff0c\u536f\u4e0d\u7a7f\u4e95\u6c34\u6cc9\u4e0d\u9999": "\u4eca\u65e5\u4e0d\u9002\u5408\u683d\u690d\uff0c\u6309\u73b0\u5728\u7684\u8bf4\u6cd5\u5e94\u8be5\u662f\u4e0d\u9002\u5408\u505a\u6709\u5f00\u521b\u6027\u8d28\u7684\u4e8b\u60c5\u3002\u4e5f\u4e0d\u9002\u5408\u5728\u8d44\u6e90\u672a\u6210\u719f\u65f6\u5f3a\u884c\u7d22\u53d6\u6216\u5f00\u53d1\u3002", "\u4e59\u4e0d\u683d\u690d\u5343\u682a\u4e0d\u957f\uff0c\u8fb0\u4e0d\u54ed\u6ce3\u5fc5\u4e3b\u91cd\u4e27": "\u4eca\u65e5\u4e0d\u9002\u5408\u683d\u690d\uff0c\u6309\u73b0\u5728\u7684\u8bf4\u6cd5\u5e94\u8be5\u662f\u4e0d\u9002\u5408\u505a\u6709\u5f00\u521b\u6027\u8d28\u7684\u4e8b\u60c5\u3002\u4e5f\u4e0d\u9002\u5408\u54ed\u6ce3\u3002\u4e5f\u5c31\u662f\u8981\u6ce8\u91cd\u4e2a\u4eba\u60c5\u7eea\u7ba1\u7406\u3002", "\u4e59\u4e0d\u683d\u690d\u5343\u682a\u4e0d\u957f\uff0c\u5df3\u4e0d\u8fdc\u884c\u8d22\u7269\u4f0f\u85cf": "\u4eca\u65e5\u4e0d\u9002\u5408\u683d\u690d\uff0c\u6309\u73b0\u5728\u7684\u8bf4\u6cd5\u5e94\u8be5\u662f\u4e0d\u9002\u5408\u505a\u6709\u5f00\u521b\u6027\u8d28\u7684\u4e8b\u60c5\u3002\u4e5f\u4e0d\u9002\u5408\u51fa\u95e8\u8fdc\u884c\uff0c\u6ce8\u610f\u8d22\u7269\u4fdd\u7ba1\uff0c\u907f\u514d\u4e22\u5931\u3002", "\u4e59\u4e0d\u683d\u690d\u5343\u682a\u4e0d\u957f\uff0c\u5348\u4e0d\u82eb\u76d6\u5c4b\u4e3b\u66f4\u5f20": "\u4eca\u65e5\u4e0d\u9002\u5408\u683d\u690d\uff0c\u6309\u73b0\u5728\u7684\u8bf4\u6cd5\u5e94\u8be5\u662f\u4e0d\u9002\u5408\u505a\u6709\u5f00\u521b\u6027\u8d28\u7684\u4e8b\u60c5\u3002\u4e5f\u4e0d\u9002\u5408\u5bf9\u623f\u5c4b\u4fee\u7f2e\uff0c\u4fee\u7406\u3002", "\u4e59\u4e0d\u683d\u690d\u5343\u682a\u4e0d\u957f\uff0c\u672a\u4e0d\u670d\u836f\u6bd2\u6c14\u5165\u80a0": "\u4eca\u65e5\u4e0d\u9002\u5408\u683d\u690d\uff0c\u6309\u73b0\u5728\u7684\u8bf4\u6cd5\u5e94\u8be5\u662f\u4e0d\u9002\u5408\u505a\u6709\u5f00\u521b\u6027\u8d28\u7684\u4e8b\u60c5\u3002\u8981\u5bf9\u5403\u836f\u8fdb\u8865\u4e4b\u7c7b\u7684\u4e8b\u60c5\u4fdd\u6301\u614e\u91cd\u3002", "\u4e59\u4e0d\u683d\u690d\u5343\u682a\u4e0d\u957f\uff0c\u7533\u4e0d\u5b89\u5e8a\u9b3c\u795f\u5165\u623f": "\u4eca\u65e5\u4e0d\u9002\u5408\u683d\u690d\uff0c\u6309\u73b0\u5728\u7684\u8bf4\u6cd5\u5e94\u8be5\u662f\u4e0d\u9002\u5408\u505a\u6709\u5f00\u521b\u6027\u8d28\u7684\u4e8b\u60c5\u3002\u4e0d\u9002\u5408\u79fb\u52a8\u3001\u5b89\u7f6e\u5e8a\u94fa\u3002", "\u4e59\u4e0d\u683d\u690d\u5343\u682a\u4e0d\u957f\uff0c\u9149\u4e0d\u4f1a\u5ba2\u9189\u5750\u98a0\u72c2": "\u4eca\u65e5\u4e0d\u9002\u5408\u683d\u690d\uff0c\u6309\u73b0\u5728\u7684\u8bf4\u6cd5\u5e94\u8be5\u662f\u4e0d\u9002\u5408\u505a\u6709\u5f00\u521b\u6027\u8d28\u7684\u4e8b\u60c5\u3002\u5982\u679c\u4eca\u65e5\u5bb4\u8bf7\u5ba2\u4eba\u6216\u8005\u8d74\u5bb4\uff0c\u8981\u5c0f\u5fc3\u559d\u9152\u559d\u9189\u3002", "\u4e59\u4e0d\u683d\u690d\u5343\u682a\u4e0d\u957f\uff0c\u620c\u4e0d\u5403\u72ac\u4f5c\u602a\u4e0a\u5e8a": "\u4eca\u65e5\u4e0d\u9002\u5408\u683d\u690d\uff0c\u6309\u73b0\u5728\u7684\u8bf4\u6cd5\u5e94\u8be5\u662f\u4e0d\u9002\u5408\u505a\u6709\u5f00\u521b\u6027\u8d28\u7684\u4e8b\u60c5\u3002\u4e0d\u8981\u5403\u72d7\u8089\u3002", "\u4e59\u4e0d\u683d\u690d\u5343\u682a\u4e0d\u957f\uff0c\u4ea5\u4e0d\u5ac1\u5a36\u4e0d\u5229\u65b0\u90ce": "\u4eca\u65e5\u4e0d\u9002\u5408\u683d\u690d\uff0c\u6309\u73b0\u5728\u7684\u8bf4\u6cd5\u5e94\u8be5\u662f\u4e0d\u9002\u5408\u505a\u6709\u5f00\u521b\u6027\u8d28\u7684\u4e8b\u60c5\u3002\u4e0d\u9002\u5408\u4eca\u65e5\u7ed3\u5a5a", "\u4e19\u4e0d\u4fee\u7076\u5fc5\u89c1\u707e\u6b83\uff0c\u5b50\u4e0d\u95ee\u535c\u81ea\u60f9\u7978\u6b83": "\u4eca\u65e5\u4e0d\u9002\u5408\u4e0d\u5e94\u8be5\u4fee\u7076\u3001\u5efa\u7076\u3002\u6309\u7167\u73b0\u4eca\u8bf4\u6cd5\u5e94\u8be5\u662f\u4e0d\u9002\u5408\u641e\u5efa\u8bbe\u4e4b\u7c7b\u7684\u4e8b\u60c5\u3002\u4e5f\u4e0d\u9002\u5408\u505a\u7b97\u547d\u3001\u95ee\u5366\u3001\u770b\u76f8\u3001\u582a\u8206\u7684\u4e8b\u60c5\uff0c\u505a\u4e86\u4e5f\u4e0d\u4e00\u5b9a\u51c6\u786e\u3002", "\u4e19\u4e0d\u4fee\u7076\u5fc5\u89c1\u707e\u6b83\uff0c\u4e11\u4e0d\u51a0\u5e26\u4e3b\u4e0d\u8fd8\u4e61": "\u4eca\u65e5\u4e0d\u9002\u5408\u4e0d\u5e94\u8be5\u4fee\u7076\u3001\u5efa\u7076\u3002\u6309\u7167\u73b0\u4eca\u8bf4\u6cd5\u5e94\u8be5\u662f\u4e0d\u9002\u5408\u641e\u5efa\u8bbe\u4e4b\u7c7b\u7684\u4e8b\u60c5\u3002\u4e5f\u4e0d\u9002\u5408\u7a7f\u65b0\u8863\u670d\uff0c\u56de\u4e61\u3001\u56de\u8001\u5bb6\u4e4b\u7c7b\u7684\u4e8b\u60c5\u3002", "\u4e19\u4e0d\u4fee\u7076\u5fc5\u89c1\u707e\u6b83\uff0c\u5bc5\u4e0d\u796d\u7940\u795e\u9b3c\u4e0d\u5c1d": "\u4eca\u65e5\u4e0d\u9002\u5408\u4e0d\u5e94\u8be5\u4fee\u7076\u3001\u5efa\u7076\u3002\u6309\u7167\u73b0\u4eca\u8bf4\u6cd5\u5e94\u8be5\u662f\u4e0d\u9002\u5408\u641e\u5efa\u8bbe\u4e4b\u7c7b\u7684\u4e8b\u60c5\u3002\u4e5f\u4e0d\u9002\u5408\u796d\u7940\u3001\u6c42\u795e\u62dc\u4f5b\u4e4b\u7c7b\u7684\u4e8b\u60c5\u3002", "\u4e19\u4e0d\u4fee\u7076\u5fc5\u89c1\u707e\u6b83\uff0c\u536f\u4e0d\u7a7f\u4e95\u6c34\u6cc9\u4e0d\u9999": "\u4eca\u65e5\u4e0d\u9002\u5408\u4e0d\u5e94\u8be5\u4fee\u7076\u3001\u5efa\u7076\u3002\u6309\u7167\u73b0\u4eca\u8bf4\u6cd5\u5e94\u8be5\u662f\u4e0d\u9002\u5408\u641e\u5efa\u8bbe\u4e4b\u7c7b\u7684\u4e8b\u60c5\u3002\u4e5f\u4e0d\u9002\u5408\u5728\u8d44\u6e90\u672a\u6210\u719f\u65f6\u5f3a\u884c\u7d22\u53d6\u6216\u5f00\u53d1\u3002", "\u4e19\u4e0d\u4fee\u7076\u5fc5\u89c1\u707e\u6b83\uff0c\u8fb0\u4e0d\u54ed\u6ce3\u5fc5\u4e3b\u91cd\u4e27": "\u4eca\u65e5\u4e0d\u9002\u5408\u4e0d\u5e94\u8be5\u4fee\u7076\u3001\u5efa\u7076\u3002\u6309\u7167\u73b0\u4eca\u8bf4\u6cd5\u5e94\u8be5\u662f\u4e0d\u9002\u5408\u641e\u5efa\u8bbe\u4e4b\u7c7b\u7684\u4e8b\u60c5\u3002\u4e5f\u4e0d\u9002\u5408\u54ed\u6ce3\u3002\u4e5f\u5c31\u662f\u8981\u6ce8\u91cd\u4e2a\u4eba\u60c5\u7eea\u7ba1\u7406\u3002", "\u4e19\u4e0d\u4fee\u7076\u5fc5\u89c1\u707e\u6b83\uff0c\u5df3\u4e0d\u8fdc\u884c\u8d22\u7269\u4f0f\u85cf": "\u4eca\u65e5\u4e0d\u9002\u5408\u4e0d\u5e94\u8be5\u4fee\u7076\u3001\u5efa\u7076\u3002\u6309\u7167\u73b0\u4eca\u8bf4\u6cd5\u5e94\u8be5\u662f\u4e0d\u9002\u5408\u641e\u5efa\u8bbe\u4e4b\u7c7b\u7684\u4e8b\u60c5\u3002\u4e5f\u4e0d\u9002\u5408\u51fa\u95e8\u8fdc\u884c\uff0c\u6ce8\u610f\u8d22\u7269\u4fdd\u7ba1\uff0c\u907f\u514d\u4e22\u5931\u3002", "\u4e19\u4e0d\u4fee\u7076\u5fc5\u89c1\u707e\u6b83\uff0c\u5348\u4e0d\u82eb\u76d6\u5c4b\u4e3b\u66f4\u5f20": "\u4eca\u65e5\u4e0d\u9002\u5408\u4e0d\u5e94\u8be5\u4fee\u7076\u3001\u5efa\u7076\u3002\u6309\u7167\u73b0\u4eca\u8bf4\u6cd5\u5e94\u8be5\u662f\u4e0d\u9002\u5408\u641e\u5efa\u8bbe\u4e4b\u7c7b\u7684\u4e8b\u60c5\u3002\u4e5f\u4e0d\u9002\u5408\u5bf9\u623f\u5c4b\u4fee\u7f2e\uff0c\u4fee\u7406\u3002", "\u4e19\u4e0d\u4fee\u7076\u5fc5\u89c1\u707e\u6b83\uff0c\u672a\u4e0d\u670d\u836f\u6bd2\u6c14\u5165\u80a0": "\u4eca\u65e5\u4e0d\u9002\u5408\u4e0d\u5e94\u8be5\u4fee\u7076\u3001\u5efa\u7076\u3002\u6309\u7167\u73b0\u4eca\u8bf4\u6cd5\u5e94\u8be5\u662f\u4e0d\u9002\u5408\u641e\u5efa\u8bbe\u4e4b\u7c7b\u7684\u4e8b\u60c5\u3002\u8981\u5bf9\u5403\u836f\u8fdb\u8865\u4e4b\u7c7b\u7684\u4e8b\u60c5\u4fdd\u6301\u614e\u91cd\u3002", "\u4e19\u4e0d\u4fee\u7076\u5fc5\u89c1\u707e\u6b83\uff0c\u7533\u4e0d\u5b89\u5e8a\u9b3c\u795f\u5165\u623f": "\u4eca\u65e5\u4e0d\u9002\u5408\u4e0d\u5e94\u8be5\u4fee\u7076\u3001\u5efa\u7076\u3002\u6309\u7167\u73b0\u4eca\u8bf4\u6cd5\u5e94\u8be5\u662f\u4e0d\u9002\u5408\u641e\u5efa\u8bbe\u4e4b\u7c7b\u7684\u4e8b\u60c5\u3002\u4e0d\u9002\u5408\u79fb\u52a8\u3001\u5b89\u7f6e\u5e8a\u94fa\u3002", "\u4e19\u4e0d\u4fee\u7076\u5fc5\u89c1\u707e\u6b83\uff0c\u9149\u4e0d\u4f1a\u5ba2\u9189\u5750\u98a0\u72c2": "\u4eca\u65e5\u4e0d\u9002\u5408\u4e0d\u5e94\u8be5\u4fee\u7076\u3001\u5efa\u7076\u3002\u6309\u7167\u73b0\u4eca\u8bf4\u6cd5\u5e94\u8be5\u662f\u4e0d\u9002\u5408\u641e\u5efa\u8bbe\u4e4b\u7c7b\u7684\u4e8b\u60c5\u3002\u5982\u679c\u4eca\u65e5\u5bb4\u8bf7\u5ba2\u4eba\u6216\u8005\u8d74\u5bb4\uff0c\u8981\u5c0f\u5fc3\u559d\u9152\u559d\u9189\u3002", "\u4e19\u4e0d\u4fee\u7076\u5fc5\u89c1\u707e\u6b83\uff0c\u620c\u4e0d\u5403\u72ac\u4f5c\u602a\u4e0a\u5e8a": "\u4eca\u65e5\u4e0d\u9002\u5408\u4e0d\u5e94\u8be5\u4fee\u7076\u3001\u5efa\u7076\u3002\u6309\u7167\u73b0\u4eca\u8bf4\u6cd5\u5e94\u8be5\u662f\u4e0d\u9002\u5408\u641e\u5efa\u8bbe\u4e4b\u7c7b\u7684\u4e8b\u60c5\u3002\u4e0d\u8981\u5403\u72d7\u8089\u3002", "\u4e19\u4e0d\u4fee\u7076\u5fc5\u89c1\u707e\u6b83\uff0c\u4ea5\u4e0d\u5ac1\u5a36\u4e0d\u5229\u65b0\u90ce": "\u4eca\u65e5\u4e0d\u9002\u5408\u4e0d\u5e94\u8be5\u4fee\u7076\u3001\u5efa\u7076\u3002\u6309\u7167\u73b0\u4eca\u8bf4\u6cd5\u5e94\u8be5\u662f\u4e0d\u9002\u5408\u641e\u5efa\u8bbe\u4e4b\u7c7b\u7684\u4e8b\u60c5\u3002\u4e0d\u9002\u5408\u4eca\u65e5\u7ed3\u5a5a", "\u4e01\u4e0d\u5243\u5934\u5934\u5fc5\u751f\u75ae\uff0c\u5b50\u4e0d\u95ee\u535c\u81ea\u60f9\u7978\u6b83": "\u4eca\u65e5\u4e0d\u9002\u5408\u5243\u5934\u3001\u7406\u53d1\uff0c\u5426\u5219\u5c31\u6709\u751f\u75ae\u3001\u60a3\u75be\u7684\u4e8b\u60c5\u53d1\u751f\u3002\u4e5f\u4e0d\u9002\u5408\u505a\u7b97\u547d\u3001\u95ee\u5366\u3001\u770b\u76f8\u3001\u582a\u8206\u7684\u4e8b\u60c5\uff0c\u505a\u4e86\u4e5f\u4e0d\u4e00\u5b9a\u51c6\u786e\u3002", "\u4e01\u4e0d\u5243\u5934\u5934\u5fc5\u751f\u75ae\uff0c\u4e11\u4e0d\u51a0\u5e26\u4e3b\u4e0d\u8fd8\u4e61": "\u4eca\u65e5\u4e0d\u9002\u5408\u5243\u5934\u3001\u7406\u53d1\uff0c\u5426\u5219\u5c31\u6709\u751f\u75ae\u3001\u60a3\u75be\u7684\u4e8b\u60c5\u53d1\u751f\u3002\u4e5f\u4e0d\u9002\u5408\u7a7f\u65b0\u8863\u670d\uff0c\u56de\u4e61\u3001\u56de\u8001\u5bb6\u4e4b\u7c7b\u7684\u4e8b\u60c5\u3002", "\u4e01\u4e0d\u5243\u5934\u5934\u5fc5\u751f\u75ae\uff0c\u5bc5\u4e0d\u796d\u7940\u795e\u9b3c\u4e0d\u5c1d": "\u4eca\u65e5\u4e0d\u9002\u5408\u5243\u5934\u3001\u7406\u53d1\uff0c\u5426\u5219\u5c31\u6709\u751f\u75ae\u3001\u60a3\u75be\u7684\u4e8b\u60c5\u53d1\u751f\u3002\u4e5f\u4e0d\u9002\u5408\u796d\u7940\u3001\u6c42\u795e\u62dc\u4f5b\u4e4b\u7c7b\u7684\u4e8b\u60c5\u3002", "\u4e01\u4e0d\u5243\u5934\u5934\u5fc5\u751f\u75ae\uff0c\u536f\u4e0d\u7a7f\u4e95\u6c34\u6cc9\u4e0d\u9999": "\u4eca\u65e5\u4e0d\u9002\u5408\u5243\u5934\u3001\u7406\u53d1\uff0c\u5426\u5219\u5c31\u6709\u751f\u75ae\u3001\u60a3\u75be\u7684\u4e8b\u60c5\u53d1\u751f\u3002\u4e5f\u4e0d\u9002\u5408\u5728\u8d44\u6e90\u672a\u6210\u719f\u65f6\u5f3a\u884c\u7d22\u53d6\u6216\u5f00\u53d1\u3002", "\u4e01\u4e0d\u5243\u5934\u5934\u5fc5\u751f\u75ae\uff0c\u8fb0\u4e0d\u54ed\u6ce3\u5fc5\u4e3b\u91cd\u4e27": "\u4eca\u65e5\u4e0d\u9002\u5408\u5243\u5934\u3001\u7406\u53d1\uff0c\u5426\u5219\u5c31\u6709\u751f\u75ae\u3001\u60a3\u75be\u7684\u4e8b\u60c5\u53d1\u751f\u3002\u4e5f\u4e0d\u9002\u5408\u54ed\u6ce3\u3002\u4e5f\u5c31\u662f\u8981\u6ce8\u91cd\u4e2a\u4eba\u60c5\u7eea\u7ba1\u7406\u3002", "\u4e01\u4e0d\u5243\u5934\u5934\u5fc5\u751f\u75ae\uff0c\u5df3\u4e0d\u8fdc\u884c\u8d22\u7269\u4f0f\u85cf": "\u4eca\u65e5\u4e0d\u9002\u5408\u5243\u5934\u3001\u7406\u53d1\uff0c\u5426\u5219\u5c31\u6709\u751f\u75ae\u3001\u60a3\u75be\u7684\u4e8b\u60c5\u53d1\u751f\u3002\u4e5f\u4e0d\u9002\u5408\u51fa\u95e8\u8fdc\u884c\uff0c\u6ce8\u610f\u8d22\u7269\u4fdd\u7ba1\uff0c\u907f\u514d\u4e22\u5931\u3002", "\u4e01\u4e0d\u5243\u5934\u5934\u5fc5\u751f\u75ae\uff0c\u5348\u4e0d\u82eb\u76d6\u5c4b\u4e3b\u66f4\u5f20": "\u4eca\u65e5\u4e0d\u9002\u5408\u5243\u5934\u3001\u7406\u53d1\uff0c\u5426\u5219\u5c31\u6709\u751f\u75ae\u3001\u60a3\u75be\u7684\u4e8b\u60c5\u53d1\u751f\u3002\u4e5f\u4e0d\u9002\u5408\u5bf9\u623f\u5c4b\u4fee\u7f2e\uff0c\u4fee\u7406\u3002", "\u4e01\u4e0d\u5243\u5934\u5934\u5fc5\u751f\u75ae\uff0c\u672a\u4e0d\u670d\u836f\u6bd2\u6c14\u5165\u80a0": "\u4eca\u65e5\u4e0d\u9002\u5408\u5243\u5934\u3001\u7406\u53d1\uff0c\u5426\u5219\u5c31\u6709\u751f\u75ae\u3001\u60a3\u75be\u7684\u4e8b\u60c5\u53d1\u751f\u3002\u8981\u5bf9\u5403\u836f\u8fdb\u8865\u4e4b\u7c7b\u7684\u4e8b\u60c5\u4fdd\u6301\u614e\u91cd\u3002", "\u4e01\u4e0d\u5243\u5934\u5934\u5fc5\u751f\u75ae\uff0c\u7533\u4e0d\u5b89\u5e8a\u9b3c\u795f\u5165\u623f": "\u4eca\u65e5\u4e0d\u9002\u5408\u5243\u5934\u3001\u7406\u53d1\uff0c\u5426\u5219\u5c31\u6709\u751f\u75ae\u3001\u60a3\u75be\u7684\u4e8b\u60c5\u53d1\u751f\u3002\u4e0d\u9002\u5408\u79fb\u52a8\u3001\u5b89\u7f6e\u5e8a\u94fa\u3002", "\u4e01\u4e0d\u5243\u5934\u5934\u5fc5\u751f\u75ae\uff0c\u9149\u4e0d\u4f1a\u5ba2\u9189\u5750\u98a0\u72c2": "\u4eca\u65e5\u4e0d\u9002\u5408\u5243\u5934\u3001\u7406\u53d1\uff0c\u5426\u5219\u5c31\u6709\u751f\u75ae\u3001\u60a3\u75be\u7684\u4e8b\u60c5\u53d1\u751f\u3002\u5982\u679c\u4eca\u65e5\u5bb4\u8bf7\u5ba2\u4eba\u6216\u8005\u8d74\u5bb4\uff0c\u8981\u5c0f\u5fc3\u559d\u9152\u559d\u9189\u3002", "\u4e01\u4e0d\u5243\u5934\u5934\u5fc5\u751f\u75ae\uff0c\u620c\u4e0d\u5403\u72ac\u4f5c\u602a\u4e0a\u5e8a": "\u4eca\u65e5\u4e0d\u9002\u5408\u5243\u5934\u3001\u7406\u53d1\uff0c\u5426\u5219\u5c31\u6709\u751f\u75ae\u3001\u60a3\u75be\u7684\u4e8b\u60c5\u53d1\u751f\u3002\u4e0d\u8981\u5403\u72d7\u8089\u3002", "\u4e01\u4e0d\u5243\u5934\u5934\u5fc5\u751f\u75ae\uff0c\u4ea5\u4e0d\u5ac1\u5a36\u4e0d\u5229\u65b0\u90ce": "\u4eca\u65e5\u4e0d\u9002\u5408\u5243\u5934\u3001\u7406\u53d1\uff0c\u5426\u5219\u5c31\u6709\u751f\u75ae\u3001\u60a3\u75be\u7684\u4e8b\u60c5\u53d1\u751f\u3002\u4e0d\u9002\u5408\u4eca\u65e5\u7ed3\u5a5a", "\u620a\u4e0d\u53d7\u7530\u7530\u4e3b\u4e0d\u7965\uff0c\u5b50\u4e0d\u95ee\u535c\u81ea\u60f9\u7978\u6b83": "\u4eca\u65e5\u4e0d\u9002\u5408\u4e70\u5356\u7530\u4ea7\u3001\u571f\u5730\u3002\u6309\u7167\u73b0\u5728\u7684\u8bf4\u6cd5\u4e0d\u9002\u5408\u7f6e\u529e\u623f\u4ea7\u3002\u4e5f\u4e0d\u9002\u5408\u505a\u7b97\u547d\u3001\u95ee\u5366\u3001\u770b\u76f8\u3001\u582a\u8206\u7684\u4e8b\u60c5\uff0c\u505a\u4e86\u4e5f\u4e0d\u4e00\u5b9a\u51c6\u786e\u3002", "\u620a\u4e0d\u53d7\u7530\u7530\u4e3b\u4e0d\u7965\uff0c\u4e11\u4e0d\u51a0\u5e26\u4e3b\u4e0d\u8fd8\u4e61": "\u4eca\u65e5\u4e0d\u9002\u5408\u4e70\u5356\u7530\u4ea7\u3001\u571f\u5730\u3002\u6309\u7167\u73b0\u5728\u7684\u8bf4\u6cd5\u4e0d\u9002\u5408\u7f6e\u529e\u623f\u4ea7\u3002\u4e5f\u4e0d\u9002\u5408\u7a7f\u65b0\u8863\u670d\uff0c\u56de\u4e61\u3001\u56de\u8001\u5bb6\u4e4b\u7c7b\u7684\u4e8b\u60c5\u3002", "\u620a\u4e0d\u53d7\u7530\u7530\u4e3b\u4e0d\u7965\uff0c\u5bc5\u4e0d\u796d\u7940\u795e\u9b3c\u4e0d\u5c1d": "\u4eca\u65e5\u4e0d\u9002\u5408\u4e70\u5356\u7530\u4ea7\u3001\u571f\u5730\u3002\u6309\u7167\u73b0\u5728\u7684\u8bf4\u6cd5\u4e0d\u9002\u5408\u7f6e\u529e\u623f\u4ea7\u3002\u4e5f\u4e0d\u9002\u5408\u796d\u7940\u3001\u6c42\u795e\u62dc\u4f5b\u4e4b\u7c7b\u7684\u4e8b\u60c5\u3002", "\u620a\u4e0d\u53d7\u7530\u7530\u4e3b\u4e0d\u7965\uff0c\u536f\u4e0d\u7a7f\u4e95\u6c34\u6cc9\u4e0d\u9999": "\u4eca\u65e5\u4e0d\u9002\u5408\u4e70\u5356\u7530\u4ea7\u3001\u571f\u5730\u3002\u6309\u7167\u73b0\u5728\u7684\u8bf4\u6cd5\u4e0d\u9002\u5408\u7f6e\u529e\u623f\u4ea7\u3002\u4e5f\u4e0d\u9002\u5408\u5728\u8d44\u6e90\u672a\u6210\u719f\u65f6\u5f3a\u884c\u7d22\u53d6\u6216\u5f00\u53d1\u3002", "\u620a\u4e0d\u53d7\u7530\u7530\u4e3b\u4e0d\u7965\uff0c\u8fb0\u4e0d\u54ed\u6ce3\u5fc5\u4e3b\u91cd\u4e27": "\u4eca\u65e5\u4e0d\u9002\u5408\u4e70\u5356\u7530\u4ea7\u3001\u571f\u5730\u3002\u6309\u7167\u73b0\u5728\u7684\u8bf4\u6cd5\u4e0d\u9002\u5408\u7f6e\u529e\u623f\u4ea7\u3002\u4e5f\u4e0d\u9002\u5408\u54ed\u6ce3\u3002\u4e5f\u5c31\u662f\u8981\u6ce8\u91cd\u4e2a\u4eba\u60c5\u7eea\u7ba1\u7406\u3002", "\u620a\u4e0d\u53d7\u7530\u7530\u4e3b\u4e0d\u7965\uff0c\u5df3\u4e0d\u8fdc\u884c\u8d22\u7269\u4f0f\u85cf": "\u4eca\u65e5\u4e0d\u9002\u5408\u4e70\u5356\u7530\u4ea7\u3001\u571f\u5730\u3002\u6309\u7167\u73b0\u5728\u7684\u8bf4\u6cd5\u4e0d\u9002\u5408\u7f6e\u529e\u623f\u4ea7\u3002\u4e5f\u4e0d\u9002\u5408\u51fa\u95e8\u8fdc\u884c\uff0c\u6ce8\u610f\u8d22\u7269\u4fdd\u7ba1\uff0c\u907f\u514d\u4e22\u5931\u3002", "\u620a\u4e0d\u53d7\u7530\u7530\u4e3b\u4e0d\u7965\uff0c\u5348\u4e0d\u82eb\u76d6\u5c4b\u4e3b\u66f4\u5f20": "\u4eca\u65e5\u4e0d\u9002\u5408\u4e70\u5356\u7530\u4ea7\u3001\u571f\u5730\u3002\u6309\u7167\u73b0\u5728\u7684\u8bf4\u6cd5\u4e0d\u9002\u5408\u7f6e\u529e\u623f\u4ea7\u3002\u4e5f\u4e0d\u9002\u5408\u5bf9\u623f\u5c4b\u4fee\u7f2e\uff0c\u4fee\u7406\u3002", "\u620a\u4e0d\u53d7\u7530\u7530\u4e3b\u4e0d\u7965\uff0c\u672a\u4e0d\u670d\u836f\u6bd2\u6c14\u5165\u80a0": "\u4eca\u65e5\u4e0d\u9002\u5408\u4e70\u5356\u7530\u4ea7\u3001\u571f\u5730\u3002\u6309\u7167\u73b0\u5728\u7684\u8bf4\u6cd5\u4e0d\u9002\u5408\u7f6e\u529e\u623f\u4ea7\u3002\u8981\u5bf9\u5403\u836f\u8fdb\u8865\u4e4b\u7c7b\u7684\u4e8b\u60c5\u4fdd\u6301\u614e\u91cd\u3002", "\u620a\u4e0d\u53d7\u7530\u7530\u4e3b\u4e0d\u7965\uff0c\u7533\u4e0d\u5b89\u5e8a\u9b3c\u795f\u5165\u623f": "\u4eca\u65e5\u4e0d\u9002\u5408\u4e70\u5356\u7530\u4ea7\u3001\u571f\u5730\u3002\u6309\u7167\u73b0\u5728\u7684\u8bf4\u6cd5\u4e0d\u9002\u5408\u7f6e\u529e\u623f\u4ea7\u3002\u4e0d\u9002\u5408\u79fb\u52a8\u3001\u5b89\u7f6e\u5e8a\u94fa\u3002", "\u620a\u4e0d\u53d7\u7530\u7530\u4e3b\u4e0d\u7965\uff0c\u9149\u4e0d\u4f1a\u5ba2\u9189\u5750\u98a0\u72c2": "\u4eca\u65e5\u4e0d\u9002\u5408\u4e70\u5356\u7530\u4ea7\u3001\u571f\u5730\u3002\u6309\u7167\u73b0\u5728\u7684\u8bf4\u6cd5\u4e0d\u9002\u5408\u7f6e\u529e\u623f\u4ea7\u3002\u5982\u679c\u4eca\u65e5\u5bb4\u8bf7\u5ba2\u4eba\u6216\u8005\u8d74\u5bb4\uff0c\u8981\u5c0f\u5fc3\u559d\u9152\u559d\u9189\u3002", "\u620a\u4e0d\u53d7\u7530\u7530\u4e3b\u4e0d\u7965\uff0c\u620c\u4e0d\u5403\u72ac\u4f5c\u602a\u4e0a\u5e8a": "\u4eca\u65e5\u4e0d\u9002\u5408\u4e70\u5356\u7530\u4ea7\u3001\u571f\u5730\u3002\u6309\u7167\u73b0\u5728\u7684\u8bf4\u6cd5\u4e0d\u9002\u5408\u7f6e\u529e\u623f\u4ea7\u3002\u4e0d\u8981\u5403\u72d7\u8089\u3002", "\u620a\u4e0d\u53d7\u7530\u7530\u4e3b\u4e0d\u7965\uff0c\u4ea5\u4e0d\u5ac1\u5a36\u4e0d\u5229\u65b0\u90ce": "\u4eca\u65e5\u4e0d\u9002\u5408\u4e70\u5356\u7530\u4ea7\u3001\u571f\u5730\u3002\u6309\u7167\u73b0\u5728\u7684\u8bf4\u6cd5\u4e0d\u9002\u5408\u7f6e\u529e\u623f\u4ea7\u3002\u4e0d\u9002\u5408\u4eca\u65e5\u7ed3\u5a5a", "\u5df1\u4e0d\u7834\u5238\u4e8c\u6bd4\u5e76\u4ea1\uff0c\u5b50\u4e0d\u95ee\u535c\u81ea\u60f9\u7978\u6b83": "\u4eca\u65e5\u4e0d\u5b9c\u4ece\u4e8b\u8ba2\u7acb\u5408\u540c\uff0c\u5951\u7ea6\u4e4b\u7c7b\u7684\u4e8b\u60c5\uff0c\u4ece\u5982\u4eca\u6765\u770b\u4e70\u80a1\u7968\u6295\u8d44\u4e5f\u5c5e\u4e8e\u8fd9\u4e00\u7c7b\u5427\u3002\u4e5f\u4e0d\u9002\u5408\u505a\u7b97\u547d\u3001\u95ee\u5366\u3001\u770b\u76f8\u3001\u582a\u8206\u7684\u4e8b\u60c5\uff0c\u505a\u4e86\u4e5f\u4e0d\u4e00\u5b9a\u51c6\u786e\u3002", "\u5df1\u4e0d\u7834\u5238\u4e8c\u6bd4\u5e76\u4ea1\uff0c\u4e11\u4e0d\u51a0\u5e26\u4e3b\u4e0d\u8fd8\u4e61": "\u4eca\u65e5\u4e0d\u5b9c\u4ece\u4e8b\u8ba2\u7acb\u5408\u540c\uff0c\u5951\u7ea6\u4e4b\u7c7b\u7684\u4e8b\u60c5\uff0c\u4ece\u5982\u4eca\u6765\u770b\u4e70\u80a1\u7968\u6295\u8d44\u4e5f\u5c5e\u4e8e\u8fd9\u4e00\u7c7b\u5427\u3002\u4e5f\u4e0d\u9002\u5408\u7a7f\u65b0\u8863\u670d\uff0c\u56de\u4e61\u3001\u56de\u8001\u5bb6\u4e4b\u7c7b\u7684\u4e8b\u60c5\u3002", "\u5df1\u4e0d\u7834\u5238\u4e8c\u6bd4\u5e76\u4ea1\uff0c\u5bc5\u4e0d\u796d\u7940\u795e\u9b3c\u4e0d\u5c1d": "\u4eca\u65e5\u4e0d\u5b9c\u4ece\u4e8b\u8ba2\u7acb\u5408\u540c\uff0c\u5951\u7ea6\u4e4b\u7c7b\u7684\u4e8b\u60c5\uff0c\u4ece\u5982\u4eca\u6765\u770b\u4e70\u80a1\u7968\u6295\u8d44\u4e5f\u5c5e\u4e8e\u8fd9\u4e00\u7c7b\u5427\u3002\u4e5f\u4e0d\u9002\u5408\u796d\u7940\u3001\u6c42\u795e\u62dc\u4f5b\u4e4b\u7c7b\u7684\u4e8b\u60c5\u3002", "\u5df1\u4e0d\u7834\u5238\u4e8c\u6bd4\u5e76\u4ea1\uff0c\u536f\u4e0d\u7a7f\u4e95\u6c34\u6cc9\u4e0d\u9999": "\u4eca\u65e5\u4e0d\u5b9c\u4ece\u4e8b\u8ba2\u7acb\u5408\u540c\uff0c\u5951\u7ea6\u4e4b\u7c7b\u7684\u4e8b\u60c5\uff0c\u4ece\u5982\u4eca\u6765\u770b\u4e70\u80a1\u7968\u6295\u8d44\u4e5f\u5c5e\u4e8e\u8fd9\u4e00\u7c7b\u5427\u3002\u4e5f\u4e0d\u9002\u5408\u5728\u8d44\u6e90\u672a\u6210\u719f\u65f6\u5f3a\u884c\u7d22\u53d6\u6216\u5f00\u53d1\u3002", "\u5df1\u4e0d\u7834\u5238\u4e8c\u6bd4\u5e76\u4ea1\uff0c\u8fb0\u4e0d\u54ed\u6ce3\u5fc5\u4e3b\u91cd\u4e27": "\u4eca\u65e5\u4e0d\u5b9c\u4ece\u4e8b\u8ba2\u7acb\u5408\u540c\uff0c\u5951\u7ea6\u4e4b\u7c7b\u7684\u4e8b\u60c5\uff0c\u4ece\u5982\u4eca\u6765\u770b\u4e70\u80a1\u7968\u6295\u8d44\u4e5f\u5c5e\u4e8e\u8fd9\u4e00\u7c7b\u5427\u3002\u4e5f\u4e0d\u9002\u5408\u54ed\u6ce3\u3002\u4e5f\u5c31\u662f\u8981\u6ce8\u91cd\u4e2a\u4eba\u60c5\u7eea\u7ba1\u7406\u3002", "\u5df1\u4e0d\u7834\u5238\u4e8c\u6bd4\u5e76\u4ea1\uff0c\u5df3\u4e0d\u8fdc\u884c\u8d22\u7269\u4f0f\u85cf": "\u4eca\u65e5\u4e0d\u5b9c\u4ece\u4e8b\u8ba2\u7acb\u5408\u540c\uff0c\u5951\u7ea6\u4e4b\u7c7b\u7684\u4e8b\u60c5\uff0c\u4ece\u5982\u4eca\u6765\u770b\u4e70\u80a1\u7968\u6295\u8d44\u4e5f\u5c5e\u4e8e\u8fd9\u4e00\u7c7b\u5427\u3002\u4e5f\u4e0d\u9002\u5408\u51fa\u95e8\u8fdc\u884c\uff0c\u6ce8\u610f\u8d22\u7269\u4fdd\u7ba1\uff0c\u907f\u514d\u4e22\u5931\u3002", "\u5df1\u4e0d\u7834\u5238\u4e8c\u6bd4\u5e76\u4ea1\uff0c\u5348\u4e0d\u82eb\u76d6\u5c4b\u4e3b\u66f4\u5f20": "\u4eca\u65e5\u4e0d\u5b9c\u4ece\u4e8b\u8ba2\u7acb\u5408\u540c\uff0c\u5951\u7ea6\u4e4b\u7c7b\u7684\u4e8b\u60c5\uff0c\u4ece\u5982\u4eca\u6765\u770b\u4e70\u80a1\u7968\u6295\u8d44\u4e5f\u5c5e\u4e8e\u8fd9\u4e00\u7c7b\u5427\u3002\u4e5f\u4e0d\u9002\u5408\u5bf9\u623f\u5c4b\u4fee\u7f2e\uff0c\u4fee\u7406\u3002", "\u5df1\u4e0d\u7834\u5238\u4e8c\u6bd4\u5e76\u4ea1\uff0c\u672a\u4e0d\u670d\u836f\u6bd2\u6c14\u5165\u80a0": "\u4eca\u65e5\u4e0d\u5b9c\u4ece\u4e8b\u8ba2\u7acb\u5408\u540c\uff0c\u5951\u7ea6\u4e4b\u7c7b\u7684\u4e8b\u60c5\uff0c\u4ece\u5982\u4eca\u6765\u770b\u4e70\u80a1\u7968\u6295\u8d44\u4e5f\u5c5e\u4e8e\u8fd9\u4e00\u7c7b\u5427\u3002\u8981\u5bf9\u5403\u836f\u8fdb\u8865\u4e4b\u7c7b\u7684\u4e8b\u60c5\u4fdd\u6301\u614e\u91cd\u3002", "\u5df1\u4e0d\u7834\u5238\u4e8c\u6bd4\u5e76\u4ea1\uff0c\u7533\u4e0d\u5b89\u5e8a\u9b3c\u795f\u5165\u623f": "\u4eca\u65e5\u4e0d\u5b9c\u4ece\u4e8b\u8ba2\u7acb\u5408\u540c\uff0c\u5951\u7ea6\u4e4b\u7c7b\u7684\u4e8b\u60c5\uff0c\u4ece\u5982\u4eca\u6765\u770b\u4e70\u80a1\u7968\u6295\u8d44\u4e5f\u5c5e\u4e8e\u8fd9\u4e00\u7c7b\u5427\u3002\u4e0d\u9002\u5408\u79fb\u52a8\u3001\u5b89\u7f6e\u5e8a\u94fa\u3002", "\u5df1\u4e0d\u7834\u5238\u4e8c\u6bd4\u5e76\u4ea1\uff0c\u9149\u4e0d\u4f1a\u5ba2\u9189\u5750\u98a0\u72c2": "\u4eca\u65e5\u4e0d\u5b9c\u4ece\u4e8b\u8ba2\u7acb\u5408\u540c\uff0c\u5951\u7ea6\u4e4b\u7c7b\u7684\u4e8b\u60c5\uff0c\u4ece\u5982\u4eca\u6765\u770b\u4e70\u80a1\u7968\u6295\u8d44\u4e5f\u5c5e\u4e8e\u8fd9\u4e00\u7c7b\u5427\u3002\u5982\u679c\u4eca\u65e5\u5bb4\u8bf7\u5ba2\u4eba\u6216\u8005\u8d74\u5bb4\uff0c\u8981\u5c0f\u5fc3\u559d\u9152\u559d\u9189\u3002", "\u5df1\u4e0d\u7834\u5238\u4e8c\u6bd4\u5e76\u4ea1\uff0c\u620c\u4e0d\u5403\u72ac\u4f5c\u602a\u4e0a\u5e8a": "\u4eca\u65e5\u4e0d\u5b9c\u4ece\u4e8b\u8ba2\u7acb\u5408\u540c\uff0c\u5951\u7ea6\u4e4b\u7c7b\u7684\u4e8b\u60c5\uff0c\u4ece\u5982\u4eca\u6765\u770b\u4e70\u80a1\u7968\u6295\u8d44\u4e5f\u5c5e\u4e8e\u8fd9\u4e00\u7c7b\u5427\u3002\u4e0d\u8981\u5403\u72d7\u8089\u3002", "\u5df1\u4e0d\u7834\u5238\u4e8c\u6bd4\u5e76\u4ea1\uff0c\u4ea5\u4e0d\u5ac1\u5a36\u4e0d\u5229\u65b0\u90ce": "\u4eca\u65e5\u4e0d\u5b9c\u4ece\u4e8b\u8ba2\u7acb\u5408\u540c\uff0c\u5951\u7ea6\u4e4b\u7c7b\u7684\u4e8b\u60c5\uff0c\u4ece\u5982\u4eca\u6765\u770b\u4e70\u80a1\u7968\u6295\u8d44\u4e5f\u5c5e\u4e8e\u8fd9\u4e00\u7c7b\u5427\u3002\u4e0d\u9002\u5408\u4eca\u65e5\u7ed3\u5a5a", "\u5e9a\u4e0d\u7ecf\u7edc\u7ec7\u673a\u865a\u5f20\uff0c\u5b50\u4e0d\u95ee\u535c\u81ea\u60f9\u7978\u6b83": "\u4eca\u65e5\u4e0d\u9002\u5408\u505a\u7ec7\u5e03\u3001\u7eba\u7ebf\u4e00\u7c7b\u7684\u4e8b\u60c5\u3002\u4e5f\u4e0d\u9002\u5408\u505a\u7b97\u547d\u3001\u95ee\u5366\u3001\u770b\u76f8\u3001\u582a\u8206\u7684\u4e8b\u60c5\uff0c\u505a\u4e86\u4e5f\u4e0d\u4e00\u5b9a\u51c6\u786e\u3002", "\u5e9a\u4e0d\u7ecf\u7edc\u7ec7\u673a\u865a\u5f20\uff0c\u4e11\u4e0d\u51a0\u5e26\u4e3b\u4e0d\u8fd8\u4e61": "\u4eca\u65e5\u4e0d\u9002\u5408\u505a\u7ec7\u5e03\u3001\u7eba\u7ebf\u4e00\u7c7b\u7684\u4e8b\u60c5\u3002\u4e5f\u4e0d\u9002\u5408\u7a7f\u65b0\u8863\u670d\uff0c\u56de\u4e61\u3001\u56de\u8001\u5bb6\u4e4b\u7c7b\u7684\u4e8b\u60c5\u3002", "\u5e9a\u4e0d\u7ecf\u7edc\u7ec7\u673a\u865a\u5f20\uff0c\u5bc5\u4e0d\u796d\u7940\u795e\u9b3c\u4e0d\u5c1d": "\u4eca\u65e5\u4e0d\u9002\u5408\u505a\u7ec7\u5e03\u3001\u7eba\u7ebf\u4e00\u7c7b\u7684\u4e8b\u60c5\u3002\u4e5f\u4e0d\u9002\u5408\u796d\u7940\u3001\u6c42\u795e\u62dc\u4f5b\u4e4b\u7c7b\u7684\u4e8b\u60c5\u3002", "\u5e9a\u4e0d\u7ecf\u7edc\u7ec7\u673a\u865a\u5f20\uff0c\u536f\u4e0d\u7a7f\u4e95\u6c34\u6cc9\u4e0d\u9999": "\u4eca\u65e5\u4e0d\u9002\u5408\u505a\u7ec7\u5e03\u3001\u7eba\u7ebf\u4e00\u7c7b\u7684\u4e8b\u60c5\u3002\u4e5f\u4e0d\u9002\u5408\u5728\u8d44\u6e90\u672a\u6210\u719f\u65f6\u5f3a\u884c\u7d22\u53d6\u6216\u5f00\u53d1\u3002", "\u5e9a\u4e0d\u7ecf\u7edc\u7ec7\u673a\u865a\u5f20\uff0c\u8fb0\u4e0d\u54ed\u6ce3\u5fc5\u4e3b\u91cd\u4e27": "\u4eca\u65e5\u4e0d\u9002\u5408\u505a\u7ec7\u5e03\u3001\u7eba\u7ebf\u4e00\u7c7b\u7684\u4e8b\u60c5\u3002\u4e5f\u4e0d\u9002\u5408\u54ed\u6ce3\u3002\u4e5f\u5c31\u662f\u8981\u6ce8\u91cd\u4e2a\u4eba\u60c5\u7eea\u7ba1\u7406\u3002", "\u5e9a\u4e0d\u7ecf\u7edc\u7ec7\u673a\u865a\u5f20\uff0c\u5df3\u4e0d\u8fdc\u884c\u8d22\u7269\u4f0f\u85cf": "\u4eca\u65e5\u4e0d\u9002\u5408\u505a\u7ec7\u5e03\u3001\u7eba\u7ebf\u4e00\u7c7b\u7684\u4e8b\u60c5\u3002\u4e5f\u4e0d\u9002\u5408\u51fa\u95e8\u8fdc\u884c\uff0c\u6ce8\u610f\u8d22\u7269\u4fdd\u7ba1\uff0c\u907f\u514d\u4e22\u5931\u3002", "\u5e9a\u4e0d\u7ecf\u7edc\u7ec7\u673a\u865a\u5f20\uff0c\u5348\u4e0d\u82eb\u76d6\u5c4b\u4e3b\u66f4\u5f20": "\u4eca\u65e5\u4e0d\u9002\u5408\u505a\u7ec7\u5e03\u3001\u7eba\u7ebf\u4e00\u7c7b\u7684\u4e8b\u60c5\u3002\u4e5f\u4e0d\u9002\u5408\u5bf9\u623f\u5c4b\u4fee\u7f2e\uff0c\u4fee\u7406\u3002", "\u5e9a\u4e0d\u7ecf\u7edc\u7ec7\u673a\u865a\u5f20\uff0c\u672a\u4e0d\u670d\u836f\u6bd2\u6c14\u5165\u80a0": "\u4eca\u65e5\u4e0d\u9002\u5408\u505a\u7ec7\u5e03\u3001\u7eba\u7ebf\u4e00\u7c7b\u7684\u4e8b\u60c5\u3002\u8981\u5bf9\u5403\u836f\u8fdb\u8865\u4e4b\u7c7b\u7684\u4e8b\u60c5\u4fdd\u6301\u614e\u91cd\u3002", "\u5e9a\u4e0d\u7ecf\u7edc\u7ec7\u673a\u865a\u5f20\uff0c\u7533\u4e0d\u5b89\u5e8a\u9b3c\u795f\u5165\u623f": "\u4eca\u65e5\u4e0d\u9002\u5408\u505a\u7ec7\u5e03\u3001\u7eba\u7ebf\u4e00\u7c7b\u7684\u4e8b\u60c5\u3002\u4e0d\u9002\u5408\u79fb\u52a8\u3001\u5b89\u7f6e\u5e8a\u94fa\u3002", "\u5e9a\u4e0d\u7ecf\u7edc\u7ec7\u673a\u865a\u5f20\uff0c\u9149\u4e0d\u4f1a\u5ba2\u9189\u5750\u98a0\u72c2": "\u4eca\u65e5\u4e0d\u9002\u5408\u505a\u7ec7\u5e03\u3001\u7eba\u7ebf\u4e00\u7c7b\u7684\u4e8b\u60c5\u3002\u5982\u679c\u4eca\u65e5\u5bb4\u8bf7\u5ba2\u4eba\u6216\u8005\u8d74\u5bb4\uff0c\u8981\u5c0f\u5fc3\u559d\u9152\u559d\u9189\u3002", "\u5e9a\u4e0d\u7ecf\u7edc\u7ec7\u673a\u865a\u5f20\uff0c\u620c\u4e0d\u5403\u72ac\u4f5c\u602a\u4e0a\u5e8a": "\u4eca\u65e5\u4e0d\u9002\u5408\u505a\u7ec7\u5e03\u3001\u7eba\u7ebf\u4e00\u7c7b\u7684\u4e8b\u60c5\u3002\u4e0d\u8981\u5403\u72d7\u8089\u3002", "\u5e9a\u4e0d\u7ecf\u7edc\u7ec7\u673a\u865a\u5f20\uff0c\u4ea5\u4e0d\u5ac1\u5a36\u4e0d\u5229\u65b0\u90ce": "\u4eca\u65e5\u4e0d\u9002\u5408\u505a\u7ec7\u5e03\u3001\u7eba\u7ebf\u4e00\u7c7b\u7684\u4e8b\u60c5\u3002\u4e0d\u9002\u5408\u4eca\u65e5\u7ed3\u5a5a", "\u8f9b\u4e0d\u5408\u9171\u4e3b\u4eba\u4e0d\u5c1d\uff0c\u5b50\u4e0d\u95ee\u535c\u81ea\u60f9\u7978\u6b83": "\u4eca\u65e5\u4e0d\u9002\u5408\u505a\u53d1\u9175\u3001\u52fe\u5151\u4e00\u7c7b\u7684\u4e8b\u60c5\u3002\u4e5f\u4e0d\u9002\u5408\u505a\u7b97\u547d\u3001\u95ee\u5366\u3001\u770b\u76f8\u3001\u582a\u8206\u7684\u4e8b\u60c5\uff0c\u505a\u4e86\u4e5f\u4e0d\u4e00\u5b9a\u51c6\u786e\u3002", "\u8f9b\u4e0d\u5408\u9171\u4e3b\u4eba\u4e0d\u5c1d\uff0c\u4e11\u4e0d\u51a0\u5e26\u4e3b\u4e0d\u8fd8\u4e61": "\u4eca\u65e5\u4e0d\u9002\u5408\u505a\u53d1\u9175\u3001\u52fe\u5151\u4e00\u7c7b\u7684\u4e8b\u60c5\u3002\u4e5f\u4e0d\u9002\u5408\u7a7f\u65b0\u8863\u670d\uff0c\u56de\u4e61\u3001\u56de\u8001\u5bb6\u4e4b\u7c7b\u7684\u4e8b\u60c5\u3002", "\u8f9b\u4e0d\u5408\u9171\u4e3b\u4eba\u4e0d\u5c1d\uff0c\u5bc5\u4e0d\u796d\u7940\u795e\u9b3c\u4e0d\u5c1d": "\u4eca\u65e5\u4e0d\u9002\u5408\u505a\u53d1\u9175\u3001\u52fe\u5151\u4e00\u7c7b\u7684\u4e8b\u60c5\u3002\u4e5f\u4e0d\u9002\u5408\u796d\u7940\u3001\u6c42\u795e\u62dc\u4f5b\u4e4b\u7c7b\u7684\u4e8b\u60c5\u3002", "\u8f9b\u4e0d\u5408\u9171\u4e3b\u4eba\u4e0d\u5c1d\uff0c\u536f\u4e0d\u7a7f\u4e95\u6c34\u6cc9\u4e0d\u9999": "\u4eca\u65e5\u4e0d\u9002\u5408\u505a\u53d1\u9175\u3001\u52fe\u5151\u4e00\u7c7b\u7684\u4e8b\u60c5\u3002\u4e5f\u4e0d\u9002\u5408\u5728\u8d44\u6e90\u672a\u6210\u719f\u65f6\u5f3a\u884c\u7d22\u53d6\u6216\u5f00\u53d1\u3002", "\u8f9b\u4e0d\u5408\u9171\u4e3b\u4eba\u4e0d\u5c1d\uff0c\u8fb0\u4e0d\u54ed\u6ce3\u5fc5\u4e3b\u91cd\u4e27": "\u4eca\u65e5\u4e0d\u9002\u5408\u505a\u53d1\u9175\u3001\u52fe\u5151\u4e00\u7c7b\u7684\u4e8b\u60c5\u3002\u4e5f\u4e0d\u9002\u5408\u54ed\u6ce3\u3002\u4e5f\u5c31\u662f\u8981\u6ce8\u91cd\u4e2a\u4eba\u60c5\u7eea\u7ba1\u7406\u3002", "\u8f9b\u4e0d\u5408\u9171\u4e3b\u4eba\u4e0d\u5c1d\uff0c\u5df3\u4e0d\u8fdc\u884c\u8d22\u7269\u4f0f\u85cf": "\u4eca\u65e5\u4e0d\u9002\u5408\u505a\u53d1\u9175\u3001\u52fe\u5151\u4e00\u7c7b\u7684\u4e8b\u60c5\u3002\u4e5f\u4e0d\u9002\u5408\u51fa\u95e8\u8fdc\u884c\uff0c\u6ce8\u610f\u8d22\u7269\u4fdd\u7ba1\uff0c\u907f\u514d\u4e22\u5931\u3002", "\u8f9b\u4e0d\u5408\u9171\u4e3b\u4eba\u4e0d\u5c1d\uff0c\u5348\u4e0d\u82eb\u76d6\u5c4b\u4e3b\u66f4\u5f20": "\u4eca\u65e5\u4e0d\u9002\u5408\u505a\u53d1\u9175\u3001\u52fe\u5151\u4e00\u7c7b\u7684\u4e8b\u60c5\u3002\u4e5f\u4e0d\u9002\u5408\u5bf9\u623f\u5c4b\u4fee\u7f2e\uff0c\u4fee\u7406\u3002", "\u8f9b\u4e0d\u5408\u9171\u4e3b\u4eba\u4e0d\u5c1d\uff0c\u672a\u4e0d\u670d\u836f\u6bd2\u6c14\u5165\u80a0": "\u4eca\u65e5\u4e0d\u9002\u5408\u505a\u53d1\u9175\u3001\u52fe\u5151\u4e00\u7c7b\u7684\u4e8b\u60c5\u3002\u8981\u5bf9\u5403\u836f\u8fdb\u8865\u4e4b\u7c7b\u7684\u4e8b\u60c5\u4fdd\u6301\u614e\u91cd\u3002", "\u8f9b\u4e0d\u5408\u9171\u4e3b\u4eba\u4e0d\u5c1d\uff0c\u7533\u4e0d\u5b89\u5e8a\u9b3c\u795f\u5165\u623f": "\u4eca\u65e5\u4e0d\u9002\u5408\u505a\u53d1\u9175\u3001\u52fe\u5151\u4e00\u7c7b\u7684\u4e8b\u60c5\u3002\u4e0d\u9002\u5408\u79fb\u52a8\u3001\u5b89\u7f6e\u5e8a\u94fa\u3002", "\u8f9b\u4e0d\u5408\u9171\u4e3b\u4eba\u4e0d\u5c1d\uff0c\u9149\u4e0d\u4f1a\u5ba2\u9189\u5750\u98a0\u72c2": "\u4eca\u65e5\u4e0d\u9002\u5408\u505a\u53d1\u9175\u3001\u52fe\u5151\u4e00\u7c7b\u7684\u4e8b\u60c5\u3002\u5982\u679c\u4eca\u65e5\u5bb4\u8bf7\u5ba2\u4eba\u6216\u8005\u8d74\u5bb4\uff0c\u8981\u5c0f\u5fc3\u559d\u9152\u559d\u9189\u3002", "\u8f9b\u4e0d\u5408\u9171\u4e3b\u4eba\u4e0d\u5c1d\uff0c\u620c\u4e0d\u5403\u72ac\u4f5c\u602a\u4e0a\u5e8a": "\u4eca\u65e5\u4e0d\u9002\u5408\u505a\u53d1\u9175\u3001\u52fe\u5151\u4e00\u7c7b\u7684\u4e8b\u60c5\u3002\u4e0d\u8981\u5403\u72d7\u8089\u3002", "\u8f9b\u4e0d\u5408\u9171\u4e3b\u4eba\u4e0d\u5c1d\uff0c\u4ea5\u4e0d\u5ac1\u5a36\u4e0d\u5229\u65b0\u90ce": "\u4eca\u65e5\u4e0d\u9002\u5408\u505a\u53d1\u9175\u3001\u52fe\u5151\u4e00\u7c7b\u7684\u4e8b\u60c5\u3002\u4e0d\u9002\u5408\u4eca\u65e5\u7ed3\u5a5a", "\u58ec\u4e0d\u6cf1\u6c34\u66f4\u96be\u63d0\u9632\uff0c\u5b50\u4e0d\u95ee\u535c\u81ea\u60f9\u7978\u6b83": "\u4eca\u65e5\u79bb\u6c5f\u3001\u6cb3\u3001\u6e56\u3001\u6d77\u3001\u7c7b\u7684\u5730\u65b9\u8fdc\u4e00\u70b9\u3002\u4e5f\u4e0d\u9002\u5408\u505a\u7b97\u547d\u3001\u95ee\u5366\u3001\u770b\u76f8\u3001\u582a\u8206\u7684\u4e8b\u60c5\uff0c\u505a\u4e86\u4e5f\u4e0d\u4e00\u5b9a\u51c6\u786e\u3002", "\u58ec\u4e0d\u6cf1\u6c34\u66f4\u96be\u63d0\u9632\uff0c\u4e11\u4e0d\u51a0\u5e26\u4e3b\u4e0d\u8fd8\u4e61": "\u4eca\u65e5\u79bb\u6c5f\u3001\u6cb3\u3001\u6e56\u3001\u6d77\u3001\u7c7b\u7684\u5730\u65b9\u8fdc\u4e00\u70b9\u3002\u4e5f\u4e0d\u9002\u5408\u7a7f\u65b0\u8863\u670d\uff0c\u56de\u4e61\u3001\u56de\u8001\u5bb6\u4e4b\u7c7b\u7684\u4e8b\u60c5\u3002", "\u58ec\u4e0d\u6cf1\u6c34\u66f4\u96be\u63d0\u9632\uff0c\u5bc5\u4e0d\u796d\u7940\u795e\u9b3c\u4e0d\u5c1d": "\u4eca\u65e5\u79bb\u6c5f\u3001\u6cb3\u3001\u6e56\u3001\u6d77\u3001\u7c7b\u7684\u5730\u65b9\u8fdc\u4e00\u70b9\u3002\u4e5f\u4e0d\u9002\u5408\u796d\u7940\u3001\u6c42\u795e\u62dc\u4f5b\u4e4b\u7c7b\u7684\u4e8b\u60c5\u3002", "\u58ec\u4e0d\u6cf1\u6c34\u66f4\u96be\u63d0\u9632\uff0c\u536f\u4e0d\u7a7f\u4e95\u6c34\u6cc9\u4e0d\u9999": "\u4eca\u65e5\u79bb\u6c5f\u3001\u6cb3\u3001\u6e56\u3001\u6d77\u3001\u7c7b\u7684\u5730\u65b9\u8fdc\u4e00\u70b9\u3002\u4e5f\u4e0d\u9002\u5408\u5728\u8d44\u6e90\u672a\u6210\u719f\u65f6\u5f3a\u884c\u7d22\u53d6\u6216\u5f00\u53d1\u3002", "\u58ec\u4e0d\u6cf1\u6c34\u66f4\u96be\u63d0\u9632\uff0c\u8fb0\u4e0d\u54ed\u6ce3\u5fc5\u4e3b\u91cd\u4e27": "\u4eca\u65e5\u79bb\u6c5f\u3001\u6cb3\u3001\u6e56\u3001\u6d77\u3001\u7c7b\u7684\u5730\u65b9\u8fdc\u4e00\u70b9\u3002\u4e5f\u4e0d\u9002\u5408\u54ed\u6ce3\u3002\u4e5f\u5c31\u662f\u8981\u6ce8\u91cd\u4e2a\u4eba\u60c5\u7eea\u7ba1\u7406\u3002", "\u58ec\u4e0d\u6cf1\u6c34\u66f4\u96be\u63d0\u9632\uff0c\u5df3\u4e0d\u8fdc\u884c\u8d22\u7269\u4f0f\u85cf": "\u4eca\u65e5\u79bb\u6c5f\u3001\u6cb3\u3001\u6e56\u3001\u6d77\u3001\u7c7b\u7684\u5730\u65b9\u8fdc\u4e00\u70b9\u3002\u4e5f\u4e0d\u9002\u5408\u51fa\u95e8\u8fdc\u884c\uff0c\u6ce8\u610f\u8d22\u7269\u4fdd\u7ba1\uff0c\u907f\u514d\u4e22\u5931\u3002", "\u58ec\u4e0d\u6cf1\u6c34\u66f4\u96be\u63d0\u9632\uff0c\u5348\u4e0d\u82eb\u76d6\u5c4b\u4e3b\u66f4\u5f20": "\u4eca\u65e5\u79bb\u6c5f\u3001\u6cb3\u3001\u6e56\u3001\u6d77\u3001\u7c7b\u7684\u5730\u65b9\u8fdc\u4e00\u70b9\u3002\u4e5f\u4e0d\u9002\u5408\u5bf9\u623f\u5c4b\u4fee\u7f2e\uff0c\u4fee\u7406\u3002", "\u58ec\u4e0d\u6cf1\u6c34\u66f4\u96be\u63d0\u9632\uff0c\u672a\u4e0d\u670d\u836f\u6bd2\u6c14\u5165\u80a0": "\u4eca\u65e5\u79bb\u6c5f\u3001\u6cb3\u3001\u6e56\u3001\u6d77\u3001\u7c7b\u7684\u5730\u65b9\u8fdc\u4e00\u70b9\u3002\u8981\u5bf9\u5403\u836f\u8fdb\u8865\u4e4b\u7c7b\u7684\u4e8b\u60c5\u4fdd\u6301\u614e\u91cd\u3002", "\u58ec\u4e0d\u6cf1\u6c34\u66f4\u96be\u63d0\u9632\uff0c\u7533\u4e0d\u5b89\u5e8a\u9b3c\u795f\u5165\u623f": "\u4eca\u65e5\u79bb\u6c5f\u3001\u6cb3\u3001\u6e56\u3001\u6d77\u3001\u7c7b\u7684\u5730\u65b9\u8fdc\u4e00\u70b9\u3002\u4e0d\u9002\u5408\u79fb\u52a8\u3001\u5b89\u7f6e\u5e8a\u94fa\u3002", "\u58ec\u4e0d\u6cf1\u6c34\u66f4\u96be\u63d0\u9632\uff0c\u9149\u4e0d\u4f1a\u5ba2\u9189\u5750\u98a0\u72c2": "\u4eca\u65e5\u79bb\u6c5f\u3001\u6cb3\u3001\u6e56\u3001\u6d77\u3001\u7c7b\u7684\u5730\u65b9\u8fdc\u4e00\u70b9\u3002\u5982\u679c\u4eca\u65e5\u5bb4\u8bf7\u5ba2\u4eba\u6216\u8005\u8d74\u5bb4\uff0c\u8981\u5c0f\u5fc3\u559d\u9152\u559d\u9189\u3002", "\u58ec\u4e0d\u6cf1\u6c34\u66f4\u96be\u63d0\u9632\uff0c\u620c\u4e0d\u5403\u72ac\u4f5c\u602a\u4e0a\u5e8a": "\u4eca\u65e5\u79bb\u6c5f\u3001\u6cb3\u3001\u6e56\u3001\u6d77\u3001\u7c7b\u7684\u5730\u65b9\u8fdc\u4e00\u70b9\u3002\u4e0d\u8981\u5403\u72d7\u8089\u3002", "\u58ec\u4e0d\u6cf1\u6c34\u66f4\u96be\u63d0\u9632\uff0c\u4ea5\u4e0d\u5ac1\u5a36\u4e0d\u5229\u65b0\u90ce": "\u4eca\u65e5\u79bb\u6c5f\u3001\u6cb3\u3001\u6e56\u3001\u6d77\u3001\u7c7b\u7684\u5730\u65b9\u8fdc\u4e00\u70b9\u3002\u4e0d\u9002\u5408\u4eca\u65e5\u7ed3\u5a5a", "\u7678\u4e0d\u8bcd\u8bbc\u7406\u5f31\u654c\u5f3a\uff0c\u5b50\u4e0d\u95ee\u535c\u81ea\u60f9\u7978\u6b83": "\u4eca\u65e5\u4e0d\u9002\u5408\u6253\u5b98\u53f8\u3001\u8bc9\u8bbc\u3001\u5435\u67b6\u3001\u548c\u522b\u4eba\u8d77\u51b2\u7a81\u4e4b\u7c7b\u7684\u4e8b\u3002\u5fcd\u4e00\u65f6\u6d77\u9614\u5929\u7a7a\u4e5f\u4e0d\u9002\u5408\u505a\u7b97\u547d\u3001\u95ee\u5366\u3001\u770b\u76f8\u3001\u582a\u8206\u7684\u4e8b\u60c5\uff0c\u505a\u4e86\u4e5f\u4e0d\u4e00\u5b9a\u51c6\u786e\u3002", "\u7678\u4e0d\u8bcd\u8bbc\u7406\u5f31\u654c\u5f3a\uff0c\u4e11\u4e0d\u51a0\u5e26\u4e3b\u4e0d\u8fd8\u4e61": "\u4eca\u65e5\u4e0d\u9002\u5408\u6253\u5b98\u53f8\u3001\u8bc9\u8bbc\u3001\u5435\u67b6\u3001\u548c\u522b\u4eba\u8d77\u51b2\u7a81\u4e4b\u7c7b\u7684\u4e8b\u3002\u5fcd\u4e00\u65f6\u6d77\u9614\u5929\u7a7a\u4e5f\u4e0d\u9002\u5408\u7a7f\u65b0\u8863\u670d\uff0c\u56de\u4e61\u3001\u56de\u8001\u5bb6\u4e4b\u7c7b\u7684\u4e8b\u60c5\u3002", "\u7678\u4e0d\u8bcd\u8bbc\u7406\u5f31\u654c\u5f3a\uff0c\u5bc5\u4e0d\u796d\u7940\u795e\u9b3c\u4e0d\u5c1d": "\u4eca\u65e5\u4e0d\u9002\u5408\u6253\u5b98\u53f8\u3001\u8bc9\u8bbc\u3001\u5435\u67b6\u3001\u548c\u522b\u4eba\u8d77\u51b2\u7a81\u4e4b\u7c7b\u7684\u4e8b\u3002\u5fcd\u4e00\u65f6\u6d77\u9614\u5929\u7a7a\u4e5f\u4e0d\u9002\u5408\u796d\u7940\u3001\u6c42\u795e\u62dc\u4f5b\u4e4b\u7c7b\u7684\u4e8b\u60c5\u3002", "\u7678\u4e0d\u8bcd\u8bbc\u7406\u5f31\u654c\u5f3a\uff0c\u536f\u4e0d\u7a7f\u4e95\u6c34\u6cc9\u4e0d\u9999": "\u4eca\u65e5\u4e0d\u9002\u5408\u6253\u5b98\u53f8\u3001\u8bc9\u8bbc\u3001\u5435\u67b6\u3001\u548c\u522b\u4eba\u8d77\u51b2\u7a81\u4e4b\u7c7b\u7684\u4e8b\u3002\u5fcd\u4e00\u65f6\u6d77\u9614\u5929\u7a7a\u4e5f\u4e0d\u9002\u5408\u5728\u8d44\u6e90\u672a\u6210\u719f\u65f6\u5f3a\u884c\u7d22\u53d6\u6216\u5f00\u53d1\u3002", "\u7678\u4e0d\u8bcd\u8bbc\u7406\u5f31\u654c\u5f3a\uff0c\u8fb0\u4e0d\u54ed\u6ce3\u5fc5\u4e3b\u91cd\u4e27": "\u4eca\u65e5\u4e0d\u9002\u5408\u6253\u5b98\u53f8\u3001\u8bc9\u8bbc\u3001\u5435\u67b6\u3001\u548c\u522b\u4eba\u8d77\u51b2\u7a81\u4e4b\u7c7b\u7684\u4e8b\u3002\u5fcd\u4e00\u65f6\u6d77\u9614\u5929\u7a7a\u4e5f\u4e0d\u9002\u5408\u54ed\u6ce3\u3002\u4e5f\u5c31\u662f\u8981\u6ce8\u91cd\u4e2a\u4eba\u60c5\u7eea\u7ba1\u7406\u3002", "\u7678\u4e0d\u8bcd\u8bbc\u7406\u5f31\u654c\u5f3a\uff0c\u5df3\u4e0d\u8fdc\u884c\u8d22\u7269\u4f0f\u85cf": "\u4eca\u65e5\u4e0d\u9002\u5408\u6253\u5b98\u53f8\u3001\u8bc9\u8bbc\u3001\u5435\u67b6\u3001\u548c\u522b\u4eba\u8d77\u51b2\u7a81\u4e4b\u7c7b\u7684\u4e8b\u3002\u5fcd\u4e00\u65f6\u6d77\u9614\u5929\u7a7a\u4e5f\u4e0d\u9002\u5408\u51fa\u95e8\u8fdc\u884c\uff0c\u6ce8\u610f\u8d22\u7269\u4fdd\u7ba1\uff0c\u907f\u514d\u4e22\u5931\u3002", "\u7678\u4e0d\u8bcd\u8bbc\u7406\u5f31\u654c\u5f3a\uff0c\u5348\u4e0d\u82eb\u76d6\u5c4b\u4e3b\u66f4\u5f20": "\u4eca\u65e5\u4e0d\u9002\u5408\u6253\u5b98\u53f8\u3001\u8bc9\u8bbc\u3001\u5435\u67b6\u3001\u548c\u522b\u4eba\u8d77\u51b2\u7a81\u4e4b\u7c7b\u7684\u4e8b\u3002\u5fcd\u4e00\u65f6\u6d77\u9614\u5929\u7a7a\u4e5f\u4e0d\u9002\u5408\u5bf9\u623f\u5c4b\u4fee\u7f2e\uff0c\u4fee\u7406\u3002", "\u7678\u4e0d\u8bcd\u8bbc\u7406\u5f31\u654c\u5f3a\uff0c\u672a\u4e0d\u670d\u836f\u6bd2\u6c14\u5165\u80a0": "\u4eca\u65e5\u4e0d\u9002\u5408\u6253\u5b98\u53f8\u3001\u8bc9\u8bbc\u3001\u5435\u67b6\u3001\u548c\u522b\u4eba\u8d77\u51b2\u7a81\u4e4b\u7c7b\u7684\u4e8b\u3002\u5fcd\u4e00\u65f6\u6d77\u9614\u5929\u7a7a\u8981\u5bf9\u5403\u836f\u8fdb\u8865\u4e4b\u7c7b\u7684\u4e8b\u60c5\u4fdd\u6301\u614e\u91cd\u3002", "\u7678\u4e0d\u8bcd\u8bbc\u7406\u5f31\u654c\u5f3a\uff0c\u7533\u4e0d\u5b89\u5e8a\u9b3c\u795f\u5165\u623f": "\u4eca\u65e5\u4e0d\u9002\u5408\u6253\u5b98\u53f8\u3001\u8bc9\u8bbc\u3001\u5435\u67b6\u3001\u548c\u522b\u4eba\u8d77\u51b2\u7a81\u4e4b\u7c7b\u7684\u4e8b\u3002\u5fcd\u4e00\u65f6\u6d77\u9614\u5929\u7a7a\u4e0d\u9002\u5408\u79fb\u52a8\u3001\u5b89\u7f6e\u5e8a\u94fa\u3002", "\u7678\u4e0d\u8bcd\u8bbc\u7406\u5f31\u654c\u5f3a\uff0c\u9149\u4e0d\u4f1a\u5ba2\u9189\u5750\u98a0\u72c2": "\u4eca\u65e5\u4e0d\u9002\u5408\u6253\u5b98\u53f8\u3001\u8bc9\u8bbc\u3001\u5435\u67b6\u3001\u548c\u522b\u4eba\u8d77\u51b2\u7a81\u4e4b\u7c7b\u7684\u4e8b\u3002\u5fcd\u4e00\u65f6\u6d77\u9614\u5929\u7a7a\u5982\u679c\u4eca\u65e5\u5bb4\u8bf7\u5ba2\u4eba\u6216\u8005\u8d74\u5bb4\uff0c\u8981\u5c0f\u5fc3\u559d\u9152\u559d\u9189\u3002", "\u7678\u4e0d\u8bcd\u8bbc\u7406\u5f31\u654c\u5f3a\uff0c\u620c\u4e0d\u5403\u72ac\u4f5c\u602a\u4e0a\u5e8a": "\u4eca\u65e5\u4e0d\u9002\u5408\u6253\u5b98\u53f8\u3001\u8bc9\u8bbc\u3001\u5435\u67b6\u3001\u548c\u522b\u4eba\u8d77\u51b2\u7a81\u4e4b\u7c7b\u7684\u4e8b\u3002\u5fcd\u4e00\u65f6\u6d77\u9614\u5929\u7a7a\u4e0d\u8981\u5403\u72d7\u8089\u3002", "\u7678\u4e0d\u8bcd\u8bbc\u7406\u5f31\u654c\u5f3a\uff0c\u4ea5\u4e0d\u5ac1\u5a36\u4e0d\u5229\u65b0\u90ce": "\u4eca\u65e5\u4e0d\u9002\u5408\u6253\u5b98\u53f8\u3001\u8bc9\u8bbc\u3001\u5435\u67b6\u3001\u548c\u522b\u4eba\u8d77\u51b2\u7a81\u4e4b\u7c7b\u7684\u4e8b\u3002\u5fcd\u4e00\u65f6\u6d77\u9614\u5929\u7a7a\u4e0d\u9002\u5408\u4eca\u65e5\u7ed3\u5a5a"}